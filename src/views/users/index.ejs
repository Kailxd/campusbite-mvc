<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Usuarios</h1>
  <a href="/usuarios/nuevo" class="btn btn-success">Nuevo usuario</a>
</div>
<table class="table table-striped table-bordered bg-white shadow-sm">
  <thead><tr><th>ID</th><th>Nombre</th><th>Correo</th><th>Rol</th><th>Acciones</th></tr></thead>
  <tbody>
    <% users.forEach(user => { %>
      <tr>
        <td><%= user.id %></td>
        <td><%= user.full_name %></td>
        <td><%= user.email %></td>
        <td><%= user.role %></td>
        <td class="d-flex gap-2">
          <a href="/usuarios/<%= user.id %>/editar" class="btn btn-sm btn-outline-primary">Editar</a>
          <form action="/usuarios/<%= user.id %>?_method=DELETE" method="POST" onsubmit="return confirm('¿Eliminar usuario?')">
            <button class="btn btn-sm btn-outline-danger">Eliminar</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
