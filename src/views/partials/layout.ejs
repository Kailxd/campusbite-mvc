<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | CampusBite</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: var(--secondary);">
    <div class="container">
      <a class="navbar-brand" href="/">CampusBite</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain"><span class="navbar-toggler-icon"></span></button>
      <div class="collapse navbar-collapse" id="navMain">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
          <% if (currentUser) { %>
            <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
            <li class="nav-item"><a class="nav-link" href="/pedidos">Pedidos</a></li>
            <% if (['admin','empleado','inventario'].includes(currentUser.role)) { %>
              <li class="nav-item"><a class="nav-link" href="/inventario">Inventario</a></li>
            <% } %>
            <% if (['admin','empleado'].includes(currentUser.role)) { %>
              <li class="nav-item"><a class="nav-link" href="/productos">Productos</a></li>
            <% } %>
            <% if (currentUser.role === 'admin') { %>
              <li class="nav-item"><a class="nav-link" href="/usuarios">Usuarios</a></li>
            <% } %>
          <% } %>
        </ul>
        <div class="d-flex align-items-center gap-2">
          <% if (currentUser) { %>
            <span class="text-white small"><%= currentUser.full_name %> (<%= currentUser.role %>)</span>
            <form action="/logout" method="POST"><button class="btn btn-outline-light btn-sm">Salir</button></form>
          <% } else { %>
            <a href="/login" class="btn btn-outline-light btn-sm">Iniciar sesión</a>
            <a href="/register" class="btn btn-warning btn-sm">Registro</a>
          <% } %>
        </div>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
    <%- body %>
  </main>

  <footer class="container pb-4"><div class="footer-note">CampusBite · Proyecto MVC académico</div></footer>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
