<div class="hero p-4 p-md-5 mb-4 shadow-sm">
  <h1 class="display-6 fw-bold">CampusBite</h1>
  <p class="mb-3">Sistema web MVC para cafetería universitaria con seguridad, CRUD y transacción de pedidos.</p>
  <% if (!currentUser) { %>
    <a href="/login" class="btn btn-light">Entrar al sistema</a>
  <% } else { %>
    <a href="/dashboard" class="btn btn-light">Ir al dashboard</a>
  <% } %>
</div>

<div class="row g-3">
  <% products.forEach(product => { %>
    <div class="col-md-6 col-lg-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <h5 class="card-title"><%= product.name %></h5>
          <p class="text-muted mb-1"><%= product.category %></p>
          <p class="mb-2"><%= product.description || 'Sin descripción' %></p>
          <div class="d-flex justify-content-between align-items-center">
            <strong>$<%= Number(product.price).toFixed(2) %></strong>
            <span class="badge text-bg-secondary">Stock: <%= product.stock %></span>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>
