<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Productos</h1>
  <a href="/productos/nuevo" class="btn btn-success">Nuevo producto</a>
</div>
<table class="table table-striped table-bordered bg-white shadow-sm">
  <thead><tr><th>ID</th><th>Nombre</th><th>Categoría</th><th>Precio</th><th>Stock</th><th>Activo</th><th>Acciones</th></tr></thead>
  <tbody>
    <% products.forEach(product => { %>
      <tr>
        <td><%= product.id %></td>
        <td><%= product.name %></td>
        <td><%= product.category %></td>
        <td>$<%= Number(product.price).toFixed(2) %></td>
        <td><%= product.stock %></td>
        <td><%= product.active ? 'Sí' : 'No' %></td>
        <td class="d-flex gap-2">
          <a class="btn btn-sm btn-outline-primary" href="/productos/<%= product.id %>/editar">Editar</a>
          <% if (currentUser.role === 'admin') { %>
          <form action="/productos/<%= product.id %>?_method=DELETE" method="POST" onsubmit="return confirm('¿Eliminar producto?')">
            <button class="btn btn-sm btn-outline-danger">Eliminar</button>
          </form>
          <% } %>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
