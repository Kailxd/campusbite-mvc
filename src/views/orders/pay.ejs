<h1 class="h3 mb-3">Pagar pedido #<%= order.id %></h1>

<div class="card shadow-sm">
  <div class="card-body">
    <p><strong>Total a pagar:</strong> $<%= Number(order.total).toFixed(2) %></p>
    <p><strong>Estado actual del pago:</strong> <%= order.payment_status %></p>

    <form action="/pedidos/<%= order.id %>/pagar" method="POST">
      <div class="mb-3">
        <label class="form-label">Método de pago</label>
        <select name="payment_method" class="form-select" required>
          <option value="">Selecciona una opción</option>
          <option value="efectivo">Efectivo</option>
          <option value="tarjeta">Tarjeta</option>
          <option value="transferencia">Transferencia</option>
        </select>
      </div>

      <button type="submit" class="btn btn-success">Confirmar pago</button>
      <a href="/pedidos/<%= order.id %>" class="btn btn-outline-secondary">Cancelar</a>
    </form>
  </div>
</div>