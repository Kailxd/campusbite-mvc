<h1 class="h3 mb-3">Nuevo pedido</h1>
<form method="POST" action="/pedidos">
  <div class="card shadow-sm"><div class="card-body">
    <div class="row g-3">
      <% products.forEach(product => { %>
        <div class="col-md-6">
          <div class="card h-100"><div class="card-body">
            <h5><%= product.name %></h5>
            <p class="mb-1 text-muted"><%= product.category %></p>
            <p class="mb-2">$<%= Number(product.price).toFixed(2) %> · Stock <%= product.stock %></p>
            <input type="hidden" name="product_id" value="<%= product.id %>">
            <label class="form-label">Cantidad</label>
            <input class="form-control" type="number" name="quantity" min="0" max="<%= product.stock %>" value="0">
          </div></div>
        </div>
      <% }) %>
    </div>
    <div class="mt-3"><button class="btn btn-success">Crear pedido</button></div>
  </div></div>
</form>
